# Server Configuration
PORT=3378

# Faster Whisper Configuration
# Path to the faster-whisper-xxl executable (absolute path recommended)
WHISPER_EXECUTABLE=/caminho/para/seu/faster-whisper-xxl

# Whisper Model (e.g., base, small, medium, large-v2, large-v3, large-v3-turbo)
WHISPER_MODEL=large-v3-turbo

# Compute Type (e.g., float16 for GPU, int8 for CPU)
WHISPER_COMPUTE_TYPE=float16

# Run On (e.g., --device cpu or empty for default GPU)
WHISPER_RUN_ON=

# Language (e.g., pt, en, es)
WHISPER_LANGUAGE=pt

# Conversion Time Rate (estimated seconds of audio per second of transcription)
CONVERSION_TIME_RATE=5
